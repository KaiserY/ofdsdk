    },
    {
      "Schema": "page",
      "Type": "TextObject",
      "Field": "CharDirection",
      "Docs": [
        {
          "Kind": "Description",
          "Text": "字符方向，指定了文字放置的方式，具体内容见 11.3 文字定位。默认值为 0。"
        }
