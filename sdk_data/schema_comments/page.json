      "Docs": [
        {
          "Kind": "Description",
          "Text": "TextCode 中字符编码的起始位置，从 0 开始。"
        }
      ]
    },
    {
      "Schema": "page",
      "Type": "CtCgTransform",
      "Field": "CodeCount",
      "Docs": [
        {
          "Kind": "Description",
          "Text": "变换关系中字符的数量，该数值应大于或等于 1，否则属于错误描述，默认为 1。"
        }
      ]
    },
    {
      "Schema": "page",
      "Type": "CtCgTransform",
      "Field": "GlyphCount",
      "Docs": [
