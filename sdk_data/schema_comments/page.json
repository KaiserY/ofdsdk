    },
    {
      "Schema": "page",
      "Type": "TextObject",
      "Field": "Weight",
      "Docs": [
        {
          "Kind": "Description",
          "Text": "文字对象的粗细值；可选取值为 100、200、300、400、500、600、700、800、900。默认值为 400。"
        }
      ]
    },
    {
      "Schema": "page",
      "Type": "TextObject",
      "Field": "Italic",
      "Docs": [
        {
          "Kind": "Description",
          "Text": "是否是斜体样式。默认值为 false。"
        }
      ]
    },
    {
      "Schema": "page",
      "Type": "TextObject",
      "Field": "FillColor",
      "Docs": [
        {
          "Kind": "Description",
          "Text": "填充颜色。默认为黑色。"
        }
      ]
    },
    {
      "Schema": "page",
      "Type": "TextObject",
      "Field": "StrokeColor",
      "Docs": [
        {
          "Kind": "Description",
          "Text": "勾边颜色。默认为透明色。"
        }
      ]
    },
    {
      "Schema": "page",
      "Type": "TextObject",
      "Field": "CGTransform",
      "Docs": [
        {
          "Kind": "Description",
          "Text": "指定字符编码到字符索引之间的变换关系，描述见 11.4 字符变换。"
        }
      ]
    },
    {
      "Schema": "page",
      "Type": "TextObject",
      "Field": "TextCode",
      "Docs": [
        {
          "Kind": "Description",
          "Text": "文字内容，也就是一段字符编码串。如果字符编码不在 XML 编码方式的字符范围之内，应采用“\\”加四位十六进制数的格式转义；文字内容中出现的空格也需要转义。若 TextCode 作为占位符使用时，一律采用“¤”(u00A4) 占位。"
        }
      ]
    },
    {
      "Schema": "page",
      "Type": "CtCgTransform",
      "Docs": [
        {
          "Kind": "Description",
          "Text": "指定字符编码到字符索引之间的变换关系，描述见 11.4 字符变换。"
        }
      ]
    },
    {
      "Schema": "page",
      "Type": "CtCgTransform",
