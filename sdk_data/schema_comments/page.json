      "Type": "TextObject",
      "Docs": [
        {
          "Kind": "Description",
          "Text": "文字对象属性，见 11.2。"
        }
      ]
    },
    {
      "Schema": "page",
      "Type": "TextObject",
      "Field": "Font",
      "Docs": [
        {
          "Kind": "Description",
          "Text": "引用资源文件中定义的字型的标识。"
        }
      ]
    },
    {
      "Schema": "page",
      "Type": "TextObject",
      "Field": "Size",
      "Docs": [
        {
          "Kind": "Description",
          "Text": "字号，单位为毫米。"
        }
      ]
    },
    {
      "Schema": "page",
      "Type": "TextObject",
      "Field": "Stroke",
      "Docs": [
        {
          "Kind": "Description",
          "Text": "是否勾边。默认值为 false。"
        }
      ]
    },
    {
      "Schema": "page",
      "Type": "TextObject",
      "Field": "Fill",
      "Docs": [
        {
          "Kind": "Description",
          "Text": "是否填充。默认值为 true。"
        }
      ]
    },
    {
      "Schema": "page",
      "Type": "TextObject",
      "Field": "HScale",
      "Docs": [
        {
          "Kind": "Description",
          "Text": "字型在水平方向的放缩比。默认值为 1.0。例如，当 HScale 值为 0.5 时表示实际显示的字宽为原来字宽的一半。"
        }
      ]
    },
    {
      "Schema": "page",
      "Type": "TextObject",
      "Field": "ReadDirection",
      "Docs": [
        {
          "Kind": "Description",
